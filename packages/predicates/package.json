{
  "name": "@studnicky/predicates",
  "version": "7.0.1",
  "description": "JSON Schema primitive validation predicates: type guards, string, numeric, array, object, content",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/predicates"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "keywords": [
    "predicates",
    "validation",
    "json-schema",
    "type-guards",
    "typescript"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@studnicky/cache": "workspace:*",
    "@studnicky/json": "workspace:*"
  }
}
