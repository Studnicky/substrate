{
  "name": "@studnicky/fsm",
  "version": "7.0.1",
  "description": "Pure reducer FSM with async effect interpreter and actor registry",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./state-machine": {
      "types": "./dist/StateMachine.d.ts",
      "import": "./dist/StateMachine.js"
    },
    "./interpreter": {
      "types": "./dist/EffectInterpreter.d.ts",
      "import": "./dist/EffectInterpreter.js"
    },
    "./registry": {
      "types": "./dist/MachineRegistry.d.ts",
      "import": "./dist/MachineRegistry.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/fsm"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "keywords": [
    "fsm",
    "state-machine",
    "finite-state-machine",
    "reducer",
    "actor",
    "typescript"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@studnicky/circular-buffer": "workspace:*",
    "@studnicky/errors": "workspace:*",
    "@studnicky/json": "workspace:*",
    "@studnicky/types": "workspace:*"
  },
  "devDependencies": {
    "@studnicky/clock": "workspace:*",
    "@studnicky/scheduler": "workspace:*",
    "@studnicky/signal": "workspace:*"
  }
}
