{
  "name": "@studnicky/sample-buffer",
  "version": "5.1.0",
  "description": "Fixed-capacity circular buffer for numeric samples with percentile calculation",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./sample-buffer": {
      "types": "./dist/sample-buffer/index.d.ts",
      "import": "./dist/sample-buffer/index.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces/index.d.ts",
      "import": "./dist/interfaces/index.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist coverage test-reports",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "keywords": [
    "sample-buffer",
    "percentile",
    "sliding-window",
    "data-structure",
    "typescript",
    "studnicky"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/sample-buffer"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "homepage": "https://studnicky.github.io/substrate/packages/sample-buffer",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "@studnicky/errors": "workspace:*",
    "@studnicky/json": "workspace:*",
    "@studnicky/types": "workspace:*"
  }
}
