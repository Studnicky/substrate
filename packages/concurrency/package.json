{
  "name": "@studnicky/concurrency",
  "version": "5.0.0",
  "description": "Async coordination primitives: Semaphore, Coalesce, Channel, AsyncIter",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./semaphore": {
      "types": "./dist/Semaphore.d.ts",
      "import": "./dist/Semaphore.js"
    },
    "./coalesce": {
      "types": "./dist/Coalesce.d.ts",
      "import": "./dist/Coalesce.js"
    },
    "./channel": {
      "types": "./dist/Channel.d.ts",
      "import": "./dist/Channel.js"
    },
    "./async-iter": {
      "types": "./dist/AsyncIter.d.ts",
      "import": "./dist/AsyncIter.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/concurrency"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "keywords": [
    "semaphore",
    "coalesce",
    "single-flight",
    "channel",
    "async-iter",
    "concurrency",
    "typescript"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@studnicky/errors": "workspace:*",
    "@studnicky/json": "workspace:*",
    "@studnicky/types": "workspace:*"
  },
  "devDependencies": {
    "@studnicky/event-bus": "workspace:*",
    "@studnicky/scheduler": "workspace:*"
  }
}
