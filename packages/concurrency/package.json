{
  "name": "@studnicky/concurrency",
  "version": "7.0.1",
  "description": "Async coordination primitives: Semaphore, Coalesce, Channel, AsyncIter",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist coverage test-reports tsconfig.tsbuildinfo",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/concurrency"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "keywords": [
    "semaphore",
    "coalesce",
    "single-flight",
    "channel",
    "async-iter",
    "concurrency",
    "typescript"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@studnicky/circular-buffer": "workspace:*",
    "@studnicky/errors": "workspace:*",
    "@studnicky/json": "workspace:*",
    "ajv": "^8.20.0",
    "json-schema-to-ts": "^3.1.1"
  },
  "devDependencies": {
    "@studnicky/event-bus": "workspace:*",
    "@studnicky/scheduler": "workspace:*"
  }
}
