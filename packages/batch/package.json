{
  "name": "@studnicky/batch",
  "version": "5.1.1",
  "description": "Batch concurrent execution for processing items in controlled batches",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./batch": {
      "types": "./dist/batch/index.d.ts",
      "import": "./dist/batch/index.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist coverage test-reports",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "keywords": [
    "batch",
    "concurrency",
    "async",
    "generator",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/batch"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "homepage": "https://studnicky.github.io/substrate/packages/batch",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "@studnicky/errors": "workspace:*"
  }
}
