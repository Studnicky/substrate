      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/signal"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "homepage": "https://studnicky.github.io/substrate/packages/signal",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "keywords": [
    "abort",
    "signal",
    "abortsignal",
    "cancellation",
    "timeout",
    "typescript"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@studnicky/errors": "workspace:*"
