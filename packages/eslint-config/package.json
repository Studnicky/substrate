{
  "name": "@studnicky/eslint-config",
  "version": "5.0.0",
  "description": "Shared ESLint flat config for @studnicky packages",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./v8": {
      "types": "./dist/v8Plugin.d.ts",
      "import": "./dist/v8Plugin.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsc --watch",
    "test": "node --import tsx --test \"tests/**/*.test.ts\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "eslint",
    "eslint-config",
    "flat-config",
    "studnicky",
    "typescript"
  ],
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/eslint-config"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "homepage": "https://studnicky.github.io/substrate/packages/eslint-config",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "peerDependencies": {
    "@stylistic/eslint-plugin": ">=5.0.0",
    "@typescript-eslint/eslint-plugin": ">=8.0.0",
    "@typescript-eslint/parser": ">=8.0.0",
    "eslint": ">=10.0.0",
    "eslint-plugin-import-x": ">=4.0.0",
    "eslint-plugin-perfectionist": ">=5.0.0",
    "eslint-plugin-regexp": ">=3.0.0",
    "eslint-plugin-unused-imports": ">=4.0.0",
    "typescript": ">=6.0.0",
    "typescript-eslint": ">=8.0.0"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/eslint": "^9.6.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.5.0",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-perfectionist": "^5.9.1",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  }
}
