{
  "name": "@studnicky/retry",
  "version": "8.0.0",
  "description": "Generic async retry utility with extensible error classification",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist coverage test-reports tsconfig.tsbuildinfo",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/retry"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "homepage": "https://studnicky.github.io/substrate/packages/retry",
  "keywords": [
    "retry",
    "async",
    "resilience",
    "backoff",
    "error-classification",
    "typescript",
    "nodejs"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "dependencies": {
    "@studnicky/config": "workspace:*",
    "@studnicky/errors": "workspace:*",
    "@studnicky/json": "workspace:*",
    "@studnicky/types": "workspace:*",
    "ajv": "^8.20.0",
    "json-schema-to-ts": "^3.1.1"
  },
  "peerDependencies": {
    "@studnicky/logger": "workspace:*",
    "@studnicky/timing": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@studnicky/logger": {
      "optional": true
    },
    "@studnicky/timing": {
      "optional": true
    }
  },
  "devDependencies": {
    "@studnicky/logger": "workspace:*",
    "@studnicky/timing": "workspace:*"
  }
}
