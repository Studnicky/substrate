{
  "name": "@studnicky/timing",
  "version": "8.0.0",
  "description": "High-resolution timing tracker for collecting operation metrics",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist coverage test-reports tsconfig.tsbuildinfo",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "keywords": [
    "timing",
    "hrtime",
    "high-resolution",
    "timing-tracker",
    "chronology",
    "events",
    "profiling",
    "benchmark"
  ],
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/timing"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "homepage": "https://studnicky.github.io/substrate/packages/timing",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "dependencies": {
    "@studnicky/config": "workspace:*",
    "@studnicky/errors": "workspace:*",
    "@studnicky/json": "workspace:*",
    "ajv": "^8.20.0",
    "json-schema-to-ts": "^3.1.1"
  }
}
