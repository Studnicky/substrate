{
  "name": "@studnicky/sliding-window-limiter",
  "version": "1.0.0",
  "description": "Sliding-window rate limiter: exact timestamp-log or approximate blended-counter algorithm",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist coverage test-reports",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/sliding-window-limiter"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "homepage": "https://studnicky.github.io/substrate/packages/sliding-window-limiter",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "keywords": [
    "rate-limiter",
    "sliding-window",
    "resilience",
    "typescript"
  ],
  "dependencies": {
    "@studnicky/circular-buffer": "workspace:*",
    "@studnicky/errors": "workspace:*",
    "@studnicky/json": "workspace:*",
    "@studnicky/signal": "workspace:*",
    "@studnicky/types": "workspace:*"
  }
}
