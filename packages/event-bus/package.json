{
  "name": "@studnicky/event-bus",
  "version": "4.0.0",
  "description": "Typed async pub/sub with per-subscriber backpressure via BusQueue",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bus-queue": {
      "types": "./dist/BusQueue.d.ts",
      "import": "./dist/BusQueue.js"
    },
    "./event-bus": {
      "types": "./dist/EventBus.d.ts",
      "import": "./dist/EventBus.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/event-bus"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "keywords": [
    "event-bus",
    "pubsub",
    "backpressure",
    "bus-queue",
    "typescript"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@studnicky/errors": "workspace:*",
    "@studnicky/json": "workspace:*",
    "@studnicky/types": "workspace:*"
  }
}
