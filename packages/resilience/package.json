{
  "name": "@studnicky/resilience",
  "version": "7.0.1",
  "description": "Async resilience primitives: CircuitBreaker, TokenBucket, DeadLetterQueue",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./circuit-breaker": {
      "types": "./dist/CircuitBreaker.d.ts",
      "import": "./dist/CircuitBreaker.js"
    },
    "./token-bucket": {
      "types": "./dist/TokenBucket.d.ts",
      "import": "./dist/TokenBucket.js"
    },
    "./dead-letter-queue": {
      "types": "./dist/DeadLetterQueue.d.ts",
      "import": "./dist/DeadLetterQueue.js"
    },
    "./dead-letter-queue/retry": {
      "types": "./dist/DeadLetterQueueRetryGenerator.d.ts",
      "import": "./dist/DeadLetterQueueRetryGenerator.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/resilience"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "keywords": [
    "circuit-breaker",
    "rate-limiter",
    "dead-letter-queue",
    "resilience",
    "typescript"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@studnicky/errors": "workspace:*",
    "@studnicky/json": "workspace:*",
    "@studnicky/signal": "workspace:*",
    "@studnicky/types": "workspace:*"
  }
}
