{
  "name": "@studnicky/virtual-fs",
  "version": "7.0.1",
  "description": "In-memory synchronous filesystem primitive with injectable clock and zero node: imports",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces/index.d.ts",
      "import": "./dist/interfaces/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist coverage test-reports",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "keywords": [
    "virtual-fs",
    "filesystem",
    "in-memory",
    "testing",
    "browser-compatible"
  ],
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/virtual-fs"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "homepage": "https://studnicky.github.io/substrate/packages/virtual-fs",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "dependencies": {
    "@studnicky/clock": "workspace:*",
    "@studnicky/errors": "workspace:*",
    "@studnicky/json": "workspace:*",
    "@studnicky/types": "workspace:*"
  }
}
