{
  "name": "@studnicky/boundary-kit",
  "version": "1.0.0",
  "description": "Boundary Kit — composes @studnicky/throttle, /resilience, and /retry into a fixed-order boundary call pattern",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist coverage test-reports",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test": "node --import tsx --test \"tests/**/*.test.ts\""
  },
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/substrate.git",
    "directory": "packages/boundary-kit"
  },
  "bugs": {
    "url": "https://github.com/Studnicky/substrate/issues"
  },
  "homepage": "https://studnicky.github.io/substrate/packages/boundary-kit",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "keywords": [
    "throttle",
    "circuit-breaker",
    "retry",
    "resilience",
    "boundary",
    "pattern",
    "typescript",
    "nodejs"
  ],
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "dependencies": {
    "@studnicky/errors": "workspace:*",
    "@studnicky/resilience": "workspace:*",
    "@studnicky/retry": "workspace:*",
    "@studnicky/throttle": "workspace:*"
  }
}
